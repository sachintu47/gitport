+void find_first_non_ascii(const char *src, size_t src_len, 
+			  size_t *line_out, size_t *col_out, 
+			  unsigned char *bad_char_out)
+{
+	size_t line = 1, col = 1;
+	unsigned char bad_char = 0;
+	for (size_t i = 0; i < src_len; i++) {
+		if (src[i] == '\n' || is_ebcdic_newline(src[i])) {
+			line++;
+			col = 1;
+		} else {
+			col++;
+		}
+		/* Try to find the first character that iconv would reject (non-ASCII) */
+		if ((unsigned char)src[i] > 0x7F) {
+			bad_char = (unsigned char)src[i];
+			break;
+		}
+	}
+	*line_out = line;
+	*col_out = col;
+	*bad_char_out = bad_char;
+}
